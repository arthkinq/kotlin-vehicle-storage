<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="500.0" spacing="15.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.LoginController">
    <stylesheets>
        <URL value="@../css/styles.css" />
    </stylesheets>
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <Label text="Vehicle Manager" styleClass="title-text">
        <VBox.margin>
            <Insets bottom="5.0" />
        </VBox.margin>
    </Label>
    <Label text="Авторизация" styleClass="subtitle-text">
        <VBox.margin>
            <Insets bottom="25.0" />
        </VBox.margin>
    </Label>

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <Label minWidth="80.0" text="Логин:" styleClass="form-label" />
        <TextField fx:id="usernameField" promptText="Введите логин" HBox.hgrow="ALWAYS" />
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <Label minWidth="80.0" text="Пароль:" styleClass="form-label" />
        <PasswordField fx:id="passwordField" promptText="Введите пароль" HBox.hgrow="ALWAYS" />
    </HBox>

    <Label fx:id="statusText" styleClass="error-text" textAlignment="CENTER" wrapText="true">
        <VBox.margin>
            <Insets top="10.0" bottom="10.0" />
        </VBox.margin>
    </Label>

    <HBox alignment="CENTER" spacing="20.0">
        <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handleLogin" text="Войти" styleClass="primary-button" prefWidth="150.0" />
        <Button fx:id="registerButton" mnemonicParsing="false" onAction="#handleRegister" text="Регистрация" styleClass="secondary-button" prefWidth="150.0" />
    </HBox>
</VBox>
