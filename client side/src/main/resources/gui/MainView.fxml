<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.canvas.Canvas?>
<?import java.net.URL?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="708.0" minWidth="1200.0"
      prefHeight="708.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.MainController">
    <stylesheets>
        <URL value="@../css/styles.css" />
    </stylesheets>
    
    <AnchorPane minWidth="1200.0" prefHeight="975.0" prefWidth="1036.0" VBox.vgrow="ALWAYS">
        <!-- Header -->
        <HBox alignment="CENTER" prefHeight="70.0" prefWidth="1200.0" spacing="100.0" 
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"
              style="-fx-background-color: white; -fx-border-color: transparent transparent #DEE2E6 transparent;">
            <Label text="Vehicle Manager" styleClass="title-text" />
            
            <HBox alignment="CENTER" spacing="40.0">
                <Label fx:id="connectionStatusLabel" text="Статус соединения" styleClass="form-label" />
                <Label fx:id="currentUserLabel" text="User: Not logged in" styleClass="form-label" />
                <Button fx:id="logoutButton" onAction="#handleLogout" text="Выйти" styleClass="secondary-button" />
            </HBox>
        </HBox>

        <TabPane layoutX="14.0" layoutY="80.0" prefHeight="610.0" prefWidth="1171.0" tabClosingPolicy="UNAVAILABLE"
                 AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0"
                 AnchorPane.topAnchor="80.0">
            <Tab fx:id="mapTab" text="Расположение объектов">
                <ScrollPane pannable="true" fitToHeight="true" fitToWidth="true" styleClass="scroll-pane">
                    <Pane fx:id="mapPane">
                        <style>
                            -fx-background-image: url("assets/map.jpg");
                            -fx-background-size: stretch;
                            -fx-background-position: center center;
                            -fx-background-repeat: no-repeat;
                        </style>
                        <Canvas fx:id="mapCanvas"/>
                    </Pane>
                </ScrollPane>
            </Tab>

            <Tab text="Таблица">
                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                    <TableView fx:id="vehicleTableView" layoutX="226.0" layoutY="7.0" prefHeight="597.0" prefWidth="941.0" 
                               AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="240.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                        <columns>
                            <TableColumn fx:id="idColumn" prefWidth="40.0" text="ID" />
                            <TableColumn fx:id="nameColumn" prefWidth="100.0" text="Имя" />
                            <TableColumn fx:id="coordXColumn" prefWidth="90.0" text="Коорд X" />
                            <TableColumn fx:id="coordYColumn" prefWidth="90.0" text="Коорд Y" />
                            <TableColumn fx:id="creationDateColumn" prefWidth="130.0" text="Дата созд." />
                            <TableColumn fx:id="enginePowerColumn" prefWidth="100.0" text="Мощность" />
                            <TableColumn fx:id="distanceColumn" prefWidth="120.0" text="Дистанция" />
                            <TableColumn fx:id="typeColumn" prefWidth="90.0" text="Тип" />
                            <TableColumn fx:id="fuelTypeColumn" prefWidth="100.0" text="Топливо" />
                            <TableColumn fx:id="userIdColumn" prefWidth="80.0" text="ID Юзера" />
                        </columns>
                    </TableView>
                    
                    <VBox AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="10.0" prefWidth="220.0" spacing="15.0">
                        <Label text="Команды:" styleClass="subtitle-text" alignment="CENTER" maxWidth="Infinity" />
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                            <VBox fx:id="commandsVBox" spacing="8.0" style="-fx-padding: 0 5 0 0;" />
                        </ScrollPane>
                    </VBox>
                </AnchorPane>
            </Tab>
        </TabPane>
    </AnchorPane>
</VBox>
